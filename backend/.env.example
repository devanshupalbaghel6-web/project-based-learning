# ============================================================================
# AI-Learn Hub Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================================

# MongoDB Configuration
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=ai_learn_hub

# Security
SECRET_KEY=your-secret-key-change-this-in-production-use-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================================================
# AI Services - Primary and Secondary LLMs
# ============================================================================

# Google Gemini API (Primary LLM - Free Tier)
# Get API key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your-google-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash-exp
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=2048

# Groq API (Secondary LLM - Lightweight tasks)
# Get API key from: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TEMPERATURE=0.5
GROQ_MAX_TOKENS=1024

# ============================================================================
# Embeddings & Vector Database
# ============================================================================

# Local Embeddings (sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

# Qdrant Vector Database - Cloud (Production)
# Get credentials from: https://cloud.qdrant.io/
# Example: https://xxx-xxx-xxx.eu-west-2-0.aws.cloud.qdrant.io:6333
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_USE_CLOUD=false

# Qdrant - Local (Development)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_LOCAL_PATH=.qdrant_data
QDRANT_COLLECTION=learning_resources
# Set true only for ephemeral in-memory usage. Keep false for persistence.
QDRANT_USE_MEMORY=false

# ============================================================================
# External APIs for Web Scraping
# ============================================================================

# GitHub API (Optional - increases rate limits)
# Get token from: https://github.com/settings/tokens
GITHUB_TOKEN=

# YouTube Data API v3
# Get from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Reddit API (Optional - for authenticated access)
# Get from: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Google Custom Search API (Optional)
# Get from: https://programmablesearchengine.google.com/
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# ============================================================================
# Optional Services
# ============================================================================

# LangChain (Optional - for tracing)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=

# Redis (Optional - for caching)
REDIS_URL=redis://localhost:6379

# CORS Origins
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
